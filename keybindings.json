[
    // ======================== R-Specific Shortcuts ========================
    // Insert an R code snippet using ```{r}...``` block
    {
        "key": "shift+cmd+r",
        "command": "editor.action.insertSnippet",
        "args": {
            "snippet": "```{r}\n$0\n```"
        },
        "when": "editorTextFocus"
    },
    {
        "key": "",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus",
        "args": {
            "snippet": "```{r}\n$0\n```"
        }
    },
    // Pipe operator shortcut for R using native pipe `|>`
    {
        "key": "cmd+shift+m",
        "command": "type",
        "args": {
            "text": " |> "
        },
        "when": "editorTextFocus"
    },
    // Insert comment block for R, useful for section headings
    {
        "key": "cmd+shift+r",
        "command": "editor.action.insertSnippet",
        "when": "editorLangId == r && editorTextFocus",
        "args": {
            "snippet": "# ${TM_SELECTED_TEXT}$0 ----"
        }
    },
    // ======================== Terminal Management ========================
    // Open a new terminal window
    {
        "key": "cmd+shift+,",
        "command": "workbench.action.terminal.new"
    },
    // Toggle terminal visibility
    {
        "key": "cmd+shift+d",
        "command": "workbench.action.terminal.toggleTerminal"
    },
    // ======================== Vim-Specific Shortcuts ========================
    // ======================== Editor Navigation ========================
    // Move between editors using directional keys (left, right, up, down)
    {
        "key": "ctrl+shift+h",
        "command": "workbench.action.navigateLeft"
    },
    {
        "key": "ctrl+shift+l",
        "command": "workbench.action.navigateRight"
    },
    {
        "key": "ctrl+shift+k",
        "command": "workbench.action.navigateUp"
    },
    {
        "key": "ctrl+shift+j",
        "command": "workbench.action.navigateDown"
    },
    {
        "key": "shift+cmd+backspace",
        "command": "workbench.action.splitEditor",
        "when": "editorTextFocus"
    },
    {
        "key": "cmd+d",
        "command": "workbench.action.toggleSidebarVisibility"
    },
    // Zoom in and out with keyboard shortcuts
    {
        "key": "ctrl+=",
        "command": "workbench.action.zoomIn"
    },
    {
        "key": "ctrl+-",
        "command": "workbench.action.zoomOut"
    },
    // Collapse all folders in the Explorer panel
    {
        "key": "shift+cmd+=",
        "command": "workbench.files.action.collapseExplorerFolders"
    },
    // ======================== Editor Management ========================
    // Navigate between open files using specific keys
    {
        "key": "cmd+]",
        "command": "workbench.action.quickOpenPreviousRecentlyUsedEditorInGroup",
        "when": "!activeEditorGroupEmpty"
    },
    {
        "key": "cmd+[",
        "command": "workbench.action.quickOpenLeastRecentlyUsedEditorInGroup",
        "when": "!activeEditorGroupEmpty"
    },
    // Open and switch through editors using Ctrl + Shift shortcuts
    {
        "key": "ctrl+shift+[",
        "command": "workbench.action.quickOpenNavigatePreviousInEditorPicker",
        "when": "inEditorsPicker && inQuickOpen"
    },
    {
        "key": "ctrl+shift+]",
        "command": "workbench.action.quickOpenNavigateNextInEditorPicker",
        "when": "inEditorsPicker && inQuickOpen"
    },
    {
        "key": "shift+cmd+g",
        "command": "-workbench.action.terminal.openDetectedLink",
        "when": "accessibleViewIsShown && terminalHasBeenCreated && accessibleViewCurrentProviderId == 'terminal'"
    },
    {
        "key": "shift+cmd+g",
        "command": "-workbench.action.terminal.findPrevious",
        "when": "terminalFindFocused && terminalHasBeenCreated || terminalFindFocused && terminalProcessSupported || terminalFocusInAny && terminalHasBeenCreated || terminalFocusInAny && terminalProcessSupported"
    },
    {
        "key": "shift+cmd+g",
        "command": "search.action.focusNextSearchResult",
        "when": "hasSearchResult || inSearchEditor"
    },
    {
        "key": "shift+cmd+/",
        "command": "workbench.action.terminal.focusNext"
    },
    {
        "key": "shift+cmd+.",
        "command": "workbench.action.terminal.focusPrevious"
    },
    {
        "key": "alt+cmd+[",
        "command": "-editor.fold",
        "when": "editorTextFocus && foldingEnabled"
    },
    {
        "key": "ctrl+enter",
        "command": "-workbench.action.chat.applyInEditor",
        "when": "accessibleViewInCodeBlock && chatIsEnabled || chatIsEnabled && inChat && !inChatInput"
    },
    {
        "key": "ctrl+enter",
        "command": "-workbench.action.chat.insertCodeBlock",
        "when": "accessibleViewInCodeBlock && chatIsEnabled || chatIsEnabled && inChat && !inChatInput"
    },
    {
        "key": "ctrl+enter",
        "command": "-github.copilot.generate",
        "when": "editorTextFocus && github.copilot.activated && !commentEditorFocused"
    },
    {
        "key": "ctrl+enter",
        "command": "r.runSelection",
        "when": "editorTextFocus && editorLangId == 'r'"
    },
    {
        "key": "z",
        "command": "-undo",
        "when": "notebookEditorFocused && !inputFocus && !notebookOutputInputFocused"
    },
    {
        "key": "cmd+k cmd+'",
        "command": "workbench.action.splitEditorRight"
    },
    {
        "key": "cmd+k cmd+\\",
        "command": "-workbench.action.splitEditorRight"
    },
    {
        "key": "cmd+k cmd+;",
        "command": "workbench.action.splitEditorLeft"
    },
    {
        "key": "cmd+k cmd+\\",
        "command": "-workbench.action.splitEditorLeft"
    },
    {
        "key": "cmd+o",
        "command": "workbench.action.quickOpen"
    },
    {
        "key": "cmd+p",
        "command": "-workbench.action.quickOpen"
    },
    {
        "key": "cmd+o",
        "command": "-workbench.action.files.openFileFolder",
        "when": "isMacNative && openFolderWorkspaceSupport"
    },
    {
        "key": "cmd+o",
        "command": "-workbench.action.files.openFolderViaWorkspace",
        "when": "!openFolderWorkspaceSupport && workbenchState == 'workspace'"
    },
    {
        "key": "cmd+o",
        "command": "-workbench.action.files.openFile",
        "when": "false"
    },
    {
        "key": "ctrl+shift+n",
        "command": "workbench.action.newWindow"
    },
    {
        "key": "shift+cmd+n",
        "command": "-workbench.action.newWindow"
    },
    {
        "key": "f",
        "command": "-notebook.find",
        "when": "notebookEditorFocused && !inputFocus && !notebookOutputInputFocused"
    },
    {
        "key": "ctrl+cmd+f",
        "command": "-workbench.action.toggleFullScreen",
        "when": "!isIOS"
    },
    {
        "key": "ctrl+f",
        "command": "-cursorRight",
        "when": "textInputFocus"
    },
    {
        "key": "ctrl+f",
        "command": "-extension.vim_ctrl+f",
        "when": "editorTextFocus && vim.active && vim.use<C-f> && !inDebugRepl && vim.mode != 'Insert'"
    },
    {
        "key": "ctrl+f",
        "command": "workbench.action.toggleFullScreen",
        "when": "!isIOS"
    }
]
